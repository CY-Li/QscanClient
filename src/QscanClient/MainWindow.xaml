<Window x:Class="QscanClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QscanClient"
        xmlns:vm="clr-namespace:QscanClient.ViewModels"
        mc:Ignorable="d"
        Title="Qscan" Height="720" Width="1120"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        Foreground="White"
        FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="1" 
                      CornerRadius="8" 
                      CaptionHeight="48" 
                      ResizeBorderThickness="7"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Main Background: Semi-transparent for Acrylic feel -->
        <SolidColorBrush x:Key="Background_Main" Color="#CC121212"/> 
        <!-- Note: We use the resource key from App.xaml but we need to reference the Color if we want to use it as a StaticResource directly or just mapping. 
             Actually App.xaml defines SolidColorBrush with keys. 
             Let's just use the App.xaml resources directly in the Grid and remove this local definition or aliases it.
             But to minimize changes in the Grid usage, I'll redefine styling here. 
             Wait, I don't can't access Color property of a Brush resource easily in XAML unless I defined Color resources. 
             I will just Replace the Grid's background usage later or define a new Brush here. -->


        <!-- Resources moved to App.xaml for global availability and crash prevention -->

        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush_Sidebar_Hover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- New Scan Card Style -->
        <Style x:Key="NewScanCardStyle" TargetType="Border">
            <Setter Property="Width" Value="164"/>
            <Setter Property="Height" Value="224"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="0,0,20,20"/>
            <Setter Property="Background" Value="{DynamicResource Brush_Accent_Gradient}"/>
            <Setter Property="Effect" Value="{DynamicResource StandardShadow}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.02" ScaleY="1.02" CenterX="82" CenterY="112"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Icon Geometries moved to App.xaml -->
        
        <!-- Scanner Icons (Online/Offline) -->
