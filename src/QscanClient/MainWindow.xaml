                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>
    </Window.Resources>

    <!-- Main Background: "Frame" with dynamic base color -->
    <Grid Background="{DynamicResource Brush_Background_Base}">
        <Grid.Style>
            <Style TargetType="Grid">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                        <Setter Property="Margin" Value="7"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- TitleBar: Transparent (Shows Frame BG) -->
        <Grid Grid.Row="0" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                <!-- App Icon -->
                <Image Source="/Assets/Icon.png" Width="20" Height="20" Margin="0,0,10,0"/>
                <!-- Logo Text if needed, or just Title -->
                <TextBlock Text="Qscan" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Brush_Text_Primary}" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                <!-- Simulation Trigger (Subtle TitleBar Action) -->
                <Button Command="{Binding SimulateScanCommand}" ToolTip="Toggle Scanning Simulation"
                        Background="Transparent" BorderThickness="0" Margin="0,0,10,0"
                        VerticalAlignment="Center" Padding="8,4" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="4" BorderBrush="{DynamicResource Brush_Border_Subtle}" BorderThickness="1">
                                <TextBlock Text="Simulate" FontSize="10" Foreground="{DynamicResource Brush_Text_Secondary}" Margin="4,2"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource Brush_Sidebar_Hover}"/>
                                    <Setter Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Style="{StaticResource CaptionButtonStyle}" Click="OnMinimizeClick">
                    <Path Data="M0,0 H10" Stroke="{DynamicResource Brush_Text_Primary}" StrokeThickness="2" Width="10" Height="2" VerticalAlignment="Center"/>
                </Button>
                <Button Style="{StaticResource CaptionButtonStyle}" Click="OnMaximizeRestoreClick">
                    <Path Data="M0,0 H10 V10 H0 Z" Stroke="{DynamicResource Brush_Text_Primary}" StrokeThickness="1.5" Width="10" Height="10" VerticalAlignment="Center"/>
                </Button>
                <Button Click="OnCloseClick">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource CaptionButtonStyle}">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Path Data="M0,0 L10,10 M0,10 L10,0" Stroke="{DynamicResource Brush_Text_Primary}" StrokeThickness="1.5" Width="10" Height="10" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar: Transparent to show Frame Gradient -->
            <Border Grid.Column="0" Background="Transparent" BorderThickness="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,16,0,0">
                        <RadioButton Style="{StaticResource SidebarRadioButtonStyle}" GroupName="Sidebar" Tag="{StaticResource Icon_Home}" Content="Home" IsChecked="True"
                                     Command="{Binding NavigateCommand}" CommandParameter="Home"/>
                        <RadioButton Style="{StaticResource SidebarRadioButtonStyle}" GroupName="Sidebar" Tag="{StaticResource Icon_Workflow}" Content="Workflow"
                                     Command="{Binding NavigateCommand}" CommandParameter="Workflow"/>

                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,16">
                        <RadioButton Style="{StaticResource SidebarRadioButtonStyle}" GroupName="Sidebar" Tag="{StaticResource Icon_Settings}" Content="Setting"
                                     Command="{Binding NavigateCommand}" CommandParameter="Settings"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content: Lighter, Transparent BG for Acrylic feel -->
            <Border Grid.Column="1" Background="{DynamicResource Brush_Background_Surface}" Opacity="0.8" CornerRadius="10,0,0,0" BorderThickness="0" ClipToBounds="False">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="0" Opacity="0.5"/>
                </Border.Effect>
                <ContentControl Content="{Binding CurrentView}"/>
            </Border>
        </Grid>

        <!-- StatusBar: Bottm alignment -->
        <Border Grid.Row="2" Background="{DynamicResource Brush_Background_Surface}" Opacity="0.9" BorderThickness="0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                <!-- Pulsing indicator if searching -->
                <Grid Margin="0,0,10,0" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource Brush_Accent}"/> <!-- Default (Searching - Orange) -->
                                <Style.Triggers>
                                    <!-- Always Pulse -->
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.2" Duration="0:0:1.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    
                                    <!-- Explicit Colors -->
                                    <DataTrigger Binding="{Binding Q30Status}" Value="{x:Static vm:Q30ConnectionStatus.Disconnected}">
                                        <Setter Property="Fill" Value="#E81123"/> <!-- Red -->
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Q30Status}" Value="{x:Static vm:Q30ConnectionStatus.Connected}">
                                        <Setter Property="Fill" Value="#4CAF50"/> <!-- Green -->
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Q30Status}" Value="{x:Static vm:Q30ConnectionStatus.WaitingForUpload}">
                                        <Setter Property="Fill" Value="#4CAF50"/> <!-- Green -->
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </Grid>

                <Image Width="20" Height="20" Margin="0,0,8,0">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Source" Value="{StaticResource ScannerOffline}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Q30Status}" Value="{x:Static vm:Q30ConnectionStatus.Connected}">
                                    <Setter Property="Source" Value="{StaticResource ScannerOnline}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Q30Status}" Value="{x:Static vm:Q30ConnectionStatus.WaitingForUpload}">
                                    <Setter Property="Source" Value="{StaticResource ScannerOnline}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
                
                <TextBlock FontSize="11" Foreground="{DynamicResource Brush_Text_Secondary}" VerticalAlignment="Center">
                    <Run Text="{Binding Q30StatusText, FallbackValue='Searching for connection...'}" FontWeight="SemiBold"/>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
