<UserControl x:Class="QscanClient.Views.DetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="32,48,32,24">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding NavigateCommand}" CommandParameter="Home" 
                        Background="Transparent" BorderThickness="0" Margin="0,0,16,0">
                    <Path Data="M19,11H7.83l5.59-5.59L12,4l-8,8l8,8l1.41-1.41L7.83,13H19V11z" 
                          Fill="{DynamicResource Brush_Text_Primary}" Width="24" Height="24" Stretch="Uniform"/>
                </Button>
                <StackPanel>
                    <TextBlock Text="{Binding SelectedBatch.Title}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource Brush_Text_Primary}"/>
                    <TextBlock Text="{Binding SelectedBatch.DateFormatted}" FontSize="13" Foreground="{DynamicResource Brush_Text_Secondary}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Export PDF" Padding="16,8" Margin="0,0,12,0" 
                        Background="{DynamicResource Brush_Accent_Gradient}" Foreground="White" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="Delete Batch" Padding="16,8" Background="Transparent" 
                        Foreground="#E81123" BorderBrush="#20000000" BorderThickness="1">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Content Area -->
        <Grid Grid.Row="1" Margin="32,0,32,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Main Preview Area -->
            <Border Grid.Column="0" Background="{DynamicResource Brush_Background_Surface}" CornerRadius="12" Margin="0,0,24,0">
                <Grid>
                    <TextBlock Text="IMAGE PREVIEW" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               Foreground="{DynamicResource Brush_Text_Secondary}" Opacity="0.3" FontSize="24" FontWeight="Bold"/>
                    <!-- Actual image preview would go here -->
                </Grid>
            </Border>

            <!-- Thumbnail Sidebar/Gallery -->
            <Border Grid.Column="1" Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" 
                    BorderBrush="{DynamicResource Brush_Border_Subtle}" BorderThickness="1">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Images (RAW JPGs)" FontWeight="SemiBold" Margin="4,0,0,12" Foreground="{DynamicResource Brush_Text_Primary}"/>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <WrapPanel Orientation="Horizontal">
                            <!-- Placeholder Image Thumbnails -->
                            <ItemsControl ItemsSource="{Binding SelectedBatch.ImagePaths}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="110" Height="150" Background="{DynamicResource Brush_Background_Base}" 
                                                Margin="4" CornerRadius="4" BorderBrush="{DynamicResource Brush_Border_Subtle}" BorderThickness="1">
                                            <Grid>
                                                <TextBlock Text="JPG" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                                           Opacity="0.2" FontSize="10" Foreground="{DynamicResource Brush_Text_Primary}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Mock thumbs if empty -->
                            <Border Width="110" Height="150" Background="{DynamicResource Brush_Background_Base}" Margin="4" CornerRadius="4"/>
                            <Border Width="110" Height="150" Background="{DynamicResource Brush_Background_Base}" Margin="4" CornerRadius="4"/>
                            <Border Width="110" Height="150" Background="{DynamicResource Brush_Background_Base}" Margin="4" CornerRadius="4"/>
                            <Border Width="110" Height="150" Background="{DynamicResource Brush_Background_Base}" Margin="4" CornerRadius="4"/>
                        </WrapPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
