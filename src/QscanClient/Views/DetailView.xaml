<UserControl x:Class="QscanClient.Views.DetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:utils="clr-namespace:QscanClient.Utils"
             mc:Ignorable="d" 
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             d:DesignHeight="700" d:DesignWidth="1000"
             Focusable="True">
    <UserControl.InputBindings>
        <KeyBinding Key="Up" Command="{Binding SelectedBatch.PreviousImageCommand}"/>
        <KeyBinding Key="Down" Command="{Binding SelectedBatch.NextImageCommand}"/>
    </UserControl.InputBindings>
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="32,48,32,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <Button Command="{Binding NavigateCommand}" CommandParameter="Home" 
                        Style="{StaticResource HeaderNeutralActionButtonStyle}" Margin="0,0,16,0" VerticalAlignment="Center" ToolTip="Go back">
                    <Path Data="{StaticResource Icon_Back}" 
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="20" Height="20" Stretch="Uniform"/>
                </Button>
                <StackPanel VerticalAlignment="Center">
                    <!-- Title Row: View Mode (TextBlock + Edit Button) -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedBatch.IsEditingTitle}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{Binding SelectedBatch.Title}" FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource Brush_Text_Primary}" VerticalAlignment="Center"/>
                        <Button Command="{Binding SelectedBatch.ToggleEditTitleCommand}"
                                Style="{StaticResource InlineEditPencilButtonStyle}"
                                Margin="8,0,0,0" VerticalAlignment="Center"
                                ToolTip="Rename batch">
                            <!-- Pencil icon -->
                            <Path Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="14" Height="14" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>

                    <!-- Title Row: Edit Mode (TextBox + Save Button) -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedBatch.IsEditingTitle}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBox x:Name="TitleEditTextBox"
                                 IsVisibleChanged="TitleEditTextBox_IsVisibleChanged"
                                 Style="{StaticResource TitleEditTextBoxStyle}"
                                 Text="{Binding SelectedBatch.EditingTitle, UpdateSourceTrigger=PropertyChanged}"
                                 MinWidth="220" VerticalAlignment="Center">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding SelectedBatch.ToggleEditTitleCommand}"/>
                                <KeyBinding Key="Escape" Command="{Binding SelectedBatch.CancelEditTitleCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <!-- Save / Confirm button -->
                        <Button Command="{Binding SelectedBatch.ToggleEditTitleCommand}"
                                Style="{StaticResource IconButtonStyle}"
                                Width="32" Height="32" Margin="6,0,0,0" VerticalAlignment="Center"
                                ToolTip="Save name">
                            <!-- Checkmark icon -->
                            <Path Data="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"
                                  Fill="{DynamicResource Brush_Accent}" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="{Binding SelectedBatch.FullDateFormatted}" FontSize="13" Foreground="{DynamicResource Brush_Text_Secondary}" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                <!-- Mail -->
                <Button Command="{Binding MailBatchCommand}"
                        Style="{StaticResource HeaderNeutralActionButtonStyle}" Margin="0,0,8,0" ToolTip="Send by Mail">
                    <Path Data="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="20" Height="20" Stretch="Uniform"/>
                </Button>
                <!-- Print -->
                <Button Command="{Binding PrintBatchCommand}"
                        Style="{StaticResource HeaderNeutralActionButtonStyle}" Margin="0,0,8,0" ToolTip="Print">
                    <Path Data="M18,3H6V7H18M19,12A1,1 0 0,1 18,11A1,1 0 0,1 19,10A1,1 0 0,1 20,11A1,1 0 0,1 19,12M16,19H8V14H16M19,8H5A3,3 0 0,0 2,11V17H6V21H18V17H22V11A3,3 0 0,0 19,8Z"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="20" Height="20" Stretch="Uniform"/>
                </Button>
                <!-- Delete -->
                <Button Command="{Binding DeleteBatchCommand}"
                        Style="{StaticResource HeaderDangerActionButtonStyle}" ToolTip="Delete Batch">
                    <Path Data="{StaticResource Icon_Delete}"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="20" Height="20" Stretch="Uniform"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Content Area -->
        <Grid Grid.Row="1" Margin="32,0,32,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Thumbnail Sidebar/Gallery (Left) -->
            <Border Grid.Column="0" Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" 
                    BorderBrush="{DynamicResource Brush_Border_Subtle}" BorderThickness="1" Margin="0,0,24,0">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding SelectedBatch.ImagePaths}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,4,4,12">
                                            <Button Command="{Binding DataContext.SelectedBatch.SelectImageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}"
                                                    Padding="0" Background="Transparent" BorderThickness="0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" Height="180" Background="{DynamicResource Brush_Background_Base}" 
                                                                CornerRadius="8" BorderBrush="{DynamicResource Brush_Border_Subtle}" BorderThickness="1">
                                                            <Grid>
                                                                <Image Source="{Binding}" Stretch="UniformToFill" Margin="2" RenderOptions.BitmapScalingMode="Fant"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush_Accent}"/>
                                                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush_Background_Alt}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            
                                            <!-- Delete Image Button (Trash Can, Hidden by default, visible on hover) -->
                                            <Button Style="{StaticResource SmallTrashButtonStyle}" 
                                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Margin="0,8,8,0"
                                                    Command="{Binding DataContext.SelectedBatch.DeleteImageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Delete Image"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Mock thumbs if empty/design time -->
                            <Border Height="180" Background="{DynamicResource Brush_Background_Base}" Margin="4,4,4,12" CornerRadius="8" Visibility="Collapsed"/>
                            <Border Height="180" Background="{DynamicResource Brush_Background_Base}" Margin="4,4,4,12" CornerRadius="8" Visibility="Collapsed"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Main Preview Area (Right) -->
            <Border Grid.Column="1" Background="{DynamicResource Brush_Background_Alt}" CornerRadius="12"
                    BorderBrush="{DynamicResource Brush_Border_Subtle}" BorderThickness="1">
                <Grid>
                    <!-- Default Placeholder -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedBatch.SelectedImagePath}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedBatch.SelectedImagePath}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Path Data="M21,19V5c0-1.1-0.9-2-2-2H5C3.9,3,3,3.9,3,5v14c0,1.1,0.9,2,2,2h14C20.1,21,21,20.1,21,19z M8.5,13.5l2.5,3.01L14.5,12l4.5,6H5L8.5,13.5z" 
                              Fill="{DynamicResource Brush_Text_Secondary}" Opacity="0.1" Stretch="Uniform" Width="64" Height="64" Margin="0,0,0,24"/>
                        <TextBlock Text="PREVIEW" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource Brush_Text_Secondary}" Opacity="0.4" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Selected Image Display (Simulation) -->
                    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="12">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedBatch.SelectedImagePath}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedBatch.SelectedImagePath}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <utils:ZoomBorder x:Name="TheZoomBorder" Background="Transparent" ClipToBounds="True" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                            <Image Source="{Binding SelectedBatch.SelectedImagePath}" 
                                   Stretch="Uniform" 
                                   RenderOptions.BitmapScalingMode="Fant"/>
                        </utils:ZoomBorder>

                        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,24"
                                Background="{DynamicResource Brush_Overlay}" CornerRadius="24" Padding="8,6"
                                BorderBrush="{DynamicResource Brush_Border_Subtle}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <Button Click="ZoomOut_Click" ToolTip="縮小 (Zoom Out)" Style="{StaticResource IconButtonStyle}" Margin="2,0">
                                    <Path Data="M15.5,14L20.5,19L19,20.5L14,15.5V14.71L13.73,14.43C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.43,13.73L14.71,14H15.5M9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14M7,9H12V10H7V9Z" 
                                          Fill="White" Width="20" Height="20" Stretch="Uniform"/>
                                </Button>
                                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="6,10" Background="#33FFFFFF"/>
                                <Button Click="Reset_Click" ToolTip="重置大小 (Fit to Screen)" Style="{StaticResource IconButtonStyle}" Margin="2,0">
                                    <Path Data="M19,12H17V15H14V17H19V12M7,9H10V7H5V12H7V9M21,3H3C1.9,3 1,3.9 1,5V19C1,20.1 1.9,21 3,21H21C22.1,21 23,20.1 23,19V5C23,3.9 22.1,3 21,3M21,19H3V5H21V19Z" 
                                          Fill="White" Width="22" Height="22" Stretch="Uniform"/>
                                </Button>
                                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="6,10" Background="#33FFFFFF"/>
                                <Button Click="ZoomIn_Click" ToolTip="放大 (Zoom In)" Style="{StaticResource IconButtonStyle}" Margin="2,0">
                                    <Path Data="M15.5,14L20.5,19L19,20.5L14,15.5V14.71L13.73,14.43C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.43,13.73L14.71,14H15.5M9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14M12,10H10V12H9V10H7V9H9V7H10V9H12V10Z" 
                                          Fill="White" Width="20" Height="20" Stretch="Uniform"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Processing Overlay for Email/Zip generation -->
        <Grid Grid.RowSpan="2" Background="{DynamicResource Brush_Overlay}" 
              Visibility="{Binding IsProcessingEmail, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Path Data="M 16 2 A 14 14 0 1 1 2 16" Stroke="{DynamicResource Brush_Accent}" StrokeThickness="3.5" StrokeEndLineCap="Round" StrokeStartLineCap="Round" Width="32" Height="32" Stretch="None" RenderTransformOrigin="0.5,0.5">
                    <Path.RenderTransform>
                        <RotateTransform x:Name="SpinnerTransform" Angle="0" />
                    </Path.RenderTransform>
                    <Path.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="SpinnerTransform" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:1" RepeatBehavior="Forever" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Path.Triggers>
                </Path>
                <TextBlock Text="Preparing email..." FontSize="14" Foreground="White" Margin="0,12,0,0" FontWeight="SemiBold" HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
