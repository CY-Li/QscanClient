<UserControl x:Class="QscanClient.Views.WorkflowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QscanClient"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Resources>
        <!-- Destination Selection Tile Style -->
        <Style x:Key="DestinationTileStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush_Elevation_Card}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Height" Value="200"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{DynamicResource StandardShadow}"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="16" BorderThickness="{TemplateBinding BorderThickness}">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush_Card_Hover}"/>
                                <Setter Property="Effect" Value="{DynamicResource WarmGlow}"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32,48,32,24">


        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="Workflows" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource Brush_Text_Primary}"/>
                <TextBlock Text="Automate your scanning routines with AI-powered naming and direct network storage" 
                           FontSize="14" Foreground="{DynamicResource Brush_Text_Secondary}" Margin="0,4,0,0" Opacity="0.8"/>
            </StackPanel>
            <Button Command="{Binding WorkflowVM.AddWorkflowCommand}" HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="{DynamicResource Brush_Accent_Gradient}" Foreground="White" BorderThickness="0" Padding="20,10" FontWeight="SemiBold" RenderTransformOrigin="0.5,0.5">
                <Button.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Button.RenderTransform>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Path x:Name="icon" Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="White" Width="16" Height="16" Margin="0,0,8,0" Stretch="Uniform"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Effect" Value="{DynamicResource WarmGlow}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                New Workflow
            </Button>
        </Grid>

        <!-- Workflow List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,-12,0">
            <ItemsControl ItemsSource="{Binding WorkflowVM.Workflows}" Margin="0,0,12,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="12">
                            <!-- Standard DocCard Parity Container -->
                            <Border x:Name="CardBorder" Width="320" Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="16" BorderThickness="0" Padding="20" Effect="{DynamicResource StandardShadow}" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Status Badges -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                        <Border Style="{StaticResource OCRBadgeStyle}" Visibility="{Binding EnableOCR, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="OCR"/>
                                        </Border>
                                        <Border Style="{StaticResource AIBadgeStyle}" Visibility="{Binding EnableAISmartNaming, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="AI SMART"/>
                                        </Border>
                                        <Border Style="{StaticResource NASBadgeStyle}" Visibility="{Binding IsNASDestination, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="NAS"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Info -->
                                    <StackPanel Grid.Row="1" Margin="0,0,0,20">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Viewbox Width="20" Height="20" Margin="0,0,12,0">
                                                <Path Data="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z" Fill="{DynamicResource Brush_Accent}"/>
                                            </Viewbox>
                                            <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource Brush_Text_Primary}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <TextBlock Text="Output Destination" FontSize="11" Foreground="{DynamicResource Brush_Text_Secondary}" Opacity="0.6" Margin="0,8,0,4"/>
                                        <TextBlock Text="{Binding TargetPath}" FontSize="13" Foreground="{DynamicResource Brush_Text_Secondary}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- Actions -->
                                    <Grid Grid.Row="2">
                                        <StackPanel Orientation="Horizontal">
                                            <Button Command="{Binding DataContext.WorkflowVM.RunWorkflowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Content="Launch" 
                                                    Background="{DynamicResource Brush_Accent_Gradient}" Foreground="White" BorderThickness="0" Padding="24,8" FontWeight="SemiBold" FontSize="12" RenderTransformOrigin="0.5,0.5">
                                                <Button.RenderTransform>
                                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                </Button.RenderTransform>
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Effect" Value="{DynamicResource WarmGlow}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Trigger.EnterActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.1"/>
                                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.1"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </Trigger.EnterActions>
                                                                <Trigger.ExitActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.1"/>
                                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.1"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </Trigger.ExitActions>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Command="{Binding DataContext.WorkflowVM.EditWorkflowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Content="Edit" Margin="12,0,0,0" RenderTransformOrigin="0.5,0.5">

                                                <Button.RenderTransform>
                                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                </Button.RenderTransform>
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ModernCardButtonStyle}">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Trigger.EnterActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.1"/>
                                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.1"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </Trigger.EnterActions>
                                                                <Trigger.ExitActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.1"/>
                                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.1"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </Trigger.ExitActions>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                        
                                        <!-- Actions on Right -->
                                        <Button Command="{Binding DataContext.WorkflowVM.DeleteWorkflowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" 
                                                HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" ToolTip="Delete Workflow">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Padding="8" CornerRadius="6" Background="Transparent">
                                                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="{DynamicResource Brush_Text_Secondary}" Width="16" Height="16" Stretch="Uniform"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#1AFF0000"/>
                                                            <Setter Property="Foreground" Value="#E81123"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>

                        <DataTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True" SourceName="CardBorder">
                                <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource Brush_Card_Hover}"/>
                                <Setter TargetName="CardBorder" Property="Effect" Value="{DynamicResource WarmGlow}"/>
                                <Setter TargetName="CardBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Destination Selection Overlay -->
        <Border Grid.RowSpan="2" Background="#AA15100C" CornerRadius="10,0,0,0" Visibility="{Binding WorkflowVM.IsSelectingDestination, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="-32 -48 -32 -24">

            <Border Width="760" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="20" BorderBrush="{DynamicResource Brush_Border_Subtle}" BorderThickness="1" Padding="48" Effect="{StaticResource StandardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border VerticalAlignment="Top" Height="4" Background="{DynamicResource Brush_Accent_Gradient}" CornerRadius="2" Margin="0,-48,0,0"/>


                    <StackPanel Grid.Row="0" Margin="0,0,0,48" HorizontalAlignment="Center">
                        <TextBlock Text="Set Scanning Destination" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource Brush_Text_Primary}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Choose where your scanned documents will be saved" FontSize="13" Foreground="{DynamicResource Brush_Text_Secondary}" Opacity="0.8" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                        <Rectangle Height="2" Fill="{DynamicResource Brush_Accent_Gradient}" HorizontalAlignment="Center" Width="60" Margin="0,16,0,0"/>
                    </StackPanel>

                    <UniformGrid Grid.Row="1" Columns="3" Margin="0,0">
                        <!-- Local PC -->
                        <Button Command="{Binding WorkflowVM.SelectDestinationCommand}" CommandParameter="LocalPC" Style="{StaticResource DestinationTileStyle}">
                            <StackPanel>
                                <Border Width="64" Height="64" Background="#1AFF8B4D" CornerRadius="16" Margin="0,0,0,24">
                                    <Path Data="M4,6H20V16H4M20,18A2,2 0 0,0 22,16V6C22,4.89 21.1,4 20,4H4C2.89,4 2,4.89 2,6V16A2,2 0 0,0 4,18H0V20H24V18" Fill="{DynamicResource Brush_Accent}" Width="32" Height="32" Stretch="Uniform"/>
                                </Border>
                                <TextBlock Text="Local PC" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource Brush_Text_Primary}"/>
                                <TextBlock Text="Standard Folder" FontSize="12" Opacity="0.7" HorizontalAlignment="Center" Foreground="{DynamicResource Brush_Text_Secondary}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- SMB -->
                        <Button Command="{Binding WorkflowVM.SelectDestinationCommand}" CommandParameter="SMB" Style="{StaticResource DestinationTileStyle}">
                            <StackPanel>
                                <Border Width="64" Height="64" Background="#1AFF8B4D" CornerRadius="16" Margin="0,0,0,24">
                                    <Path Data="M4,1H11L12,2H20A2,2 0 0,1 22,4V18A2,2 0 0,1 20,20H4C2.89,20 2,19.1 2,18V3C2,1.89 2.89,1 4,1M11,13H13V17H11V13M11,7H13V11H11V7" Fill="{DynamicResource Brush_Accent}" Width="32" Height="32" Stretch="Uniform"/>
                                </Border>
                                <TextBlock Text="NAS / SMB" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource Brush_Text_Primary}"/>
                                <TextBlock Text="Network Storage" FontSize="12" Opacity="0.7" HorizontalAlignment="Center" Foreground="{DynamicResource Brush_Text_Secondary}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- FTP -->
                        <Button Command="{Binding WorkflowVM.SelectDestinationCommand}" CommandParameter="FTP" Style="{StaticResource DestinationTileStyle}">
                            <StackPanel>
                                <Border Width="64" Height="64" Background="#1AFF8B4D" CornerRadius="16" Margin="0,0,0,24">
                                    <Path Data="M19.35,10.04C18.67,6.59 15.64,4 12,4C9.11,4 6.6,5.64 5.35,8.04C2.34,8.36 0,10.91 0,14A6,6 0 0,0 6,20H19A5,5 0 0,0 24,15C24,12.36 21.95,10.22 19.35,10.04M19,18H6A4,4 0 0,1 2,14C2,11.79 3.8,10 6,10C6.3,10 6.6,10.03 6.9,10.1C7.74,7.69 10,6 12,6C14.76,6 17,8.24 17,11V12H19A3,3 0 0,1 22,15A3,3 0 0,1 19,18Z" Fill="{DynamicResource Brush_Accent}" Width="32" Height="32" Stretch="Uniform"/>
                                </Border>
                                <TextBlock Text="FTP / Cloud" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource Brush_Text_Primary}"/>
                                <TextBlock Text="Remote Access" FontSize="12" Opacity="0.7" HorizontalAlignment="Center" Foreground="{DynamicResource Brush_Text_Secondary}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </UniformGrid>

                    <Button Grid.Row="2" Command="{Binding WorkflowVM.CancelSelectionCommand}" Content="Cancel and return to gallery" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,48,0,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="{TemplateBinding Content}" FontSize="12" TextDecorations="Underline" Foreground="{DynamicResource Brush_Text_Secondary}" Opacity="0.8">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource Brush_Accent}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Border>



    </Grid>
</UserControl>
