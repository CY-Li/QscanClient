<UserControl x:Class="QscanClient.Views.WorkflowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QscanClient"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Resources>
        <!-- Destination Selection Tile Style -->
        <Style x:Key="DestinationTileStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush_Elevation_Card}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Height" Value="200"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{DynamicResource StandardShadow}"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="16" BorderThickness="{TemplateBinding BorderThickness}">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush_Card_Hover}"/>
                                <Setter Property="Effect" Value="{DynamicResource WarmGlow}"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32,48,32,24">


        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,32">
            <TextBlock Text="Workflow" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource Brush_Text_Primary}" VerticalAlignment="Center"/>
            <Button Command="{Binding WorkflowVM.AddWorkflowCommand}" HorizontalAlignment="Right" VerticalAlignment="Center"
                    Style="{StaticResource HeaderPrimaryActionButtonStyle}" ToolTip="Create new workflow">
                <Path Data="{StaticResource Icon_Add}" Fill="White" Width="20" Height="20" Stretch="Uniform"/>
            </Button>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <!-- Workflow List (Visible when NOT empty) -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,-12,0">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding WorkflowVM.IsEmpty}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ItemsControl ItemsSource="{Binding WorkflowVM.Workflows}" Margin="0,0,12,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="12">
                            <!-- Standard DocCard Parity Container -->
                            <Border x:Name="CardBorder" Width="320" Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="16" BorderThickness="1" Padding="20" Effect="{DynamicResource StandardShadow}" RenderTransformOrigin="0.5,0.5">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="Margin" Value="0,0,0,0"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <ThicknessAnimation Storyboard.TargetProperty="Margin" To="0,-4,0,4" Duration="0:0:0.2">
                                                                <ThicknessAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut"/>
                                                                </ThicknessAnimation.EasingFunction>
                                                            </ThicknessAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <ThicknessAnimation Storyboard.TargetProperty="Margin" To="0,0,0,0" Duration="0:0:0.2">
                                                                <ThicknessAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut"/>
                                                                </ThicknessAnimation.EasingFunction>
                                                            </ThicknessAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Interaction Layer -->
                                    <Button Grid.RowSpan="3" Command="{Binding DataContext.WorkflowVM.EditWorkflowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            CommandParameter="{Binding}"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Edit Workflow">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent" BorderThickness="0"/>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Status Badges removed -->

                                    <!-- Info -->
                                    <StackPanel Grid.Row="1" Margin="0,0,0,20" IsHitTestVisible="False">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Viewbox Width="20" Height="20" Margin="0,0,12,0">
                                                <Path Fill="{DynamicResource Brush_Accent}" Stretch="Uniform">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <!-- Default PC -->
                                                            <Setter Property="Data" Value="M320-120v-80h80v-80H160q-33 0-56.5-23.5T80-360v-400q0-33 23.5-56.5T160-840h640q33 0 56.5 23.5T880-760v400q0 33-23.5 56.5T800-280H560v80h80v80H320ZM160-360h640v-400H160v400Zm0 0v-400 400Z"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DestinationType}" Value="SMB">
                                                                    <Setter Property="Data" Value="M543.5-63.5Q520-87 520-120q0-23 11-41t29-29v-221q-18-11-29-28.5T520-480q0-33 23.5-56.5T600-560q33 0 56.5 23.5T680-480q0 23-11 40.5T640-411v115l160-53v-62q-18-11-29-28.5T760-480q0-33 23.5-56.5T840-560q33 0 56.5 23.5T920-480q0 23-11 40.5T880-411v119l-240 80v22q18 11 29 29t11 41q0 33-23.5 56.5T600-40q-33 0-56.5-23.5ZM160-160v-560 560Zm0 0q-33 0-56.5-23.5T80-240v-480q0-33 23.5-56.5T160-800h240l80 80h320q33 0 56.5 23.5T880-640H447l-80-80H160v480h280v80H160Z"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding DestinationType}" Value="FTP">
                                                                    <Setter Property="Data" Value="{StaticResource Icon_FTP}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </Viewbox>
                                            <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource Brush_Text_Primary}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <TextBlock Text="Output Destination" FontSize="11" Foreground="{DynamicResource Brush_Text_Secondary}" Opacity="0.6" Margin="0,8,0,4"/>
                                        <TextBlock Text="{Binding DisplayTargetPath}" FontSize="13" Foreground="{DynamicResource Brush_Text_Secondary}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- Actions -->
                                    <Grid Grid.Row="2">
                                        <!-- Edit Button Removed -->
                                        
                                        <!-- Actions on Right -->
                                        <Button Command="{Binding DataContext.WorkflowVM.DeleteWorkflowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" 
                                                HorizontalAlignment="Right" Style="{StaticResource HeaderDangerActionButtonStyle}" ToolTip="Delete Workflow">
                                            <Path Data="{StaticResource Icon_Delete}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="16" Height="16" Stretch="Uniform"/>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>

                        <DataTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True" SourceName="CardBorder">
                                <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource Brush_Card_Hover}"/>
                                <Setter TargetName="CardBorder" Property="Effect" Value="{DynamicResource WarmGlow}"/>
                                <Setter TargetName="CardBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

            <!-- Empty State (Visible when empty) -->
            <Grid x:Name="EmptyStateOverlay">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding WorkflowVM.IsEmpty}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <!-- Guidance Arrow (Top Right) -->
                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,0,80,0" Opacity="0.6">
                    <Path Data="M 0,40 Q 20,40 40,0 M 40,0 L 30,10 M 40,0 L 45,15" Stroke="{DynamicResource Brush_Accent}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="80" Height="80" Stretch="Uniform" Margin="0,0,0,10"/>
                    <TextBlock Text="Get Started" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Brush_Accent}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Center Message -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,40">
                    <Border Width="120" Height="120" Background="{DynamicResource Brush_Accent_Transparent}" CornerRadius="60" Margin="0,0,0,32">
                        <Path Data="{StaticResource Icon_Workflow}" Fill="{DynamicResource Brush_Accent}" Opacity="0.3" Width="56" Height="56" Stretch="Uniform"/>
                    </Border>
                    <TextBlock Text="No Workflows Found" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource Brush_Text_Primary}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Click the button to create your first scanning workflow." FontSize="14" Foreground="{DynamicResource Brush_Text_Secondary}" Margin="0,12,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Destination Selection Overlay -->
        <Border x:Name="OverlayBorder" Grid.RowSpan="2" Background="{DynamicResource Brush_Overlay}" CornerRadius="10,0,0,0" 
                Visibility="{Binding WorkflowVM.IsSelectingDestination, Converter={StaticResource BooleanToVisibilityConverter}}" 
                Margin="-32 -48 -32 -24" PreviewMouseLeftButtonDown="OverlayBorder_PreviewMouseLeftButtonDown">

            <Border Width="760" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="20" BorderBrush="{DynamicResource Brush_Border_Subtle}" BorderThickness="1" Padding="48" Effect="{StaticResource StandardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border VerticalAlignment="Top" Height="4" Background="{DynamicResource Brush_Accent_Gradient}" CornerRadius="2" Margin="0,-48,0,0"/>


                    <StackPanel Grid.Row="0" Margin="0,0,0,48" HorizontalAlignment="Center">
                        <TextBlock Text="Set Scanning Destination" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource Brush_Text_Primary}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Choose where your scanned documents will be saved" FontSize="13" Foreground="{DynamicResource Brush_Text_Secondary}" Opacity="0.8" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                        <Rectangle Height="2" Fill="{DynamicResource Brush_Accent_Gradient}" HorizontalAlignment="Center" Width="60" Margin="0,16,0,0"/>
                    </StackPanel>

                    <UniformGrid Grid.Row="1" Columns="3" Margin="0,0">
                        <!-- Local PC -->
                        <Button Command="{Binding WorkflowVM.SelectDestinationCommand}" CommandParameter="LocalPC" Style="{StaticResource DestinationTileStyle}">
                            <StackPanel>
                                <Border Width="64" Height="64" Background="{DynamicResource Brush_Accent_Transparent}" CornerRadius="16" Margin="0,0,0,24">
                                    <Path Data="M320-120v-80h80v-80H160q-33 0-56.5-23.5T80-360v-400q0-33 23.5-56.5T160-840h640q33 0 56.5 23.5T880-760v400q0 33-23.5 56.5T800-280H560v80h80v80H320ZM160-360h640v-400H160v400Zm0 0v-400 400Z" Fill="{DynamicResource Brush_Accent}" Width="32" Height="32" Stretch="Uniform"/>
                                </Border>
                                <TextBlock Text="This PC" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource Brush_Text_Primary}"/>
                            </StackPanel>
                        </Button>

                        <!-- SMB -->
                        <Button Command="{Binding WorkflowVM.SelectDestinationCommand}" CommandParameter="SMB" Style="{StaticResource DestinationTileStyle}">
                            <StackPanel>
                                <Border Width="64" Height="64" Background="{DynamicResource Brush_Accent_Transparent}" CornerRadius="16" Margin="0,0,0,24">
                                    <Path Data="M543.5-63.5Q520-87 520-120q0-23 11-41t29-29v-221q-18-11-29-28.5T520-480q0-33 23.5-56.5T600-560q33 0 56.5 23.5T680-480q0 23-11 40.5T640-411v115l160-53v-62q-18-11-29-28.5T760-480q0-33 23.5-56.5T840-560q33 0 56.5 23.5T920-480q0 23-11 40.5T880-411v119l-240 80v22q18 11 29 29t11 41q0 33-23.5 56.5T600-40q-33 0-56.5-23.5ZM160-160v-560 560Zm0 0q-33 0-56.5-23.5T80-240v-480q0-33 23.5-56.5T160-800h240l80 80h320q33 0 56.5 23.5T880-640H447l-80-80H160v480h280v80H160Z" Fill="{DynamicResource Brush_Accent}" Width="32" Height="32" Stretch="Uniform"/>
                                </Border>
                                <TextBlock Text="Shared Folder" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource Brush_Text_Primary}"/>
                            </StackPanel>
                        </Button>

                        <!-- FTP -->
                        <Button Command="{Binding WorkflowVM.SelectDestinationCommand}" CommandParameter="FTP" Style="{StaticResource DestinationTileStyle}">
                            <StackPanel>
                                <Border Width="64" Height="64" Background="{DynamicResource Brush_Accent_Transparent}" CornerRadius="16" Margin="0,0,0,24">
                                    <Path Data="M467-120q-73-1-136-14t-110-34.5q-47-21.5-74-50T120-280q0 33 27 61.5t74 50Q268-147 331-134t136 14Zm-15-200q-38-2-73.5-6.5t-67.5-12q-32-7.5-60-17.5t-51-23q23 13 51 23t60 17.5q32 7.5 67.5 12T452-320Zm28-279q89 0 179-26.5T760-679q-11-29-100.5-55T480-760q-91 0-178.5 25.5T200-679q14 27 101.5 53.5T480-599Zm220 479h40v-164l72 72 28-28-120-120-120 120 28 28 72-72v164ZM578.5-98.5Q520-157 520-240t58.5-141.5Q637-440 720-440t141.5 58.5Q920-323 920-240T861.5-98.5Q803-40 720-40T578.5-98.5ZM443-201q3 22 9 42t15 39q-73-1-136-14t-110-34.5q-47-21.5-74-50T120-280v-400q0-66 105.5-113T480-840q149 0 254.5 47T840-680v187q-19-9-39-15t-41-9v-62q-52 29-124 44t-156 15q-85 0-157-15t-123-44v101q51 47 130.5 62.5T480-400h11q-13 18-22.5 38T452-320q-76-4-141-18.5T200-379v99q7 13 30 26.5t56 24q33 10.5 73.5 18T443-201Z" Fill="{DynamicResource Brush_Accent}" Width="32" Height="32" Stretch="Uniform"/>
                                </Border>
                                <TextBlock Text="FTP / SFTP" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource Brush_Text_Primary}"/>
                            </StackPanel>
                        </Button>
                    </UniformGrid>

                    <!-- <Button Grid.Row="2" Command="{Binding WorkflowVM.CancelSelectionCommand}" Content="Cancel" 
                            Style="{StaticResource ModernCardButtonStyle}" 
                            VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,48,0,0" Padding="32,8"/> -->
                </Grid>
            </Border>
        </Border>



    </Grid>
</UserControl>
