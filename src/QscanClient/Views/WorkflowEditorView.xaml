<UserControl x:Class="QscanClient.Views.WorkflowEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QscanClient"
             xmlns:converters="clr-namespace:QscanClient.Converters"

             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Loaded="UserControl_Loaded">
    <UserControl.Resources>
        <converters:EnumValueToBooleanConverter x:Key="EnumValueToBooleanConverter"/>
        
        <!-- Visual Dashboard Tile Style -->
        <Style x:Key="VisualTileRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="{DynamicResource Brush_Elevation_Card}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="16" Margin="4" Padding="{TemplateBinding Padding}" Effect="{StaticResource StandardShadow}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush_Accent}"/>
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush_Accent_Transparent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush_Accent}"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Opacity" Value="1"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32,48,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Command="{Binding WorkflowEditorVM.CancelCommand}" 
                        Style="{StaticResource HeaderNeutralActionButtonStyle}" Margin="0,0,16,0" VerticalAlignment="Center" ToolTip="Go back">
                    <Path Data="{StaticResource Icon_Back}" 
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="20" Height="20" Stretch="Uniform"/>
                </Button>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="{DynamicResource Brush_Text_Primary}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Edit Workflow"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WorkflowEditorVM.IsNewWorkflow}" Value="True">
                                        <Setter Property="Text" Value="Create Workflow"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="Set up your automated scanning preferences" FontSize="13" Foreground="{DynamicResource Brush_Text_Secondary}"/>
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="1" Command="{Binding WorkflowEditorVM.SaveCommand}" 
                    Style="{StaticResource HeaderPrimaryActionButtonStyle}" 
                    VerticalAlignment="Center" ToolTip="Save changes">
                <Path Data="{StaticResource Icon_Save}" 
                      Fill="White" Width="20" Height="20" Stretch="Uniform"/>
            </Button>
        </Grid>

        <!-- Main Form Area -->
        <ScrollViewer x:Name="MainScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,-24,-24" Padding="0,0,24,24">
            <Grid Margin="0,0,0,40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5*"/>
                    <ColumnDefinition Width="4*"/>
                </Grid.ColumnDefinitions>

                <!-- ================= LEFT COLUMN: IDENTIFICATION & DESTINATION ================= -->
                <StackPanel Grid.Column="0" Margin="0,0,40,0">
                    <TextBlock Text="Workflow Name" Foreground="{DynamicResource Brush_Text_Secondary}" FontSize="13" Margin="4,0,0,8"/>
                    <StackPanel Margin="0,0,0,0">
                        <Border Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" MinHeight="64" Effect="{StaticResource StandardShadow}">
                            <TextBox Text="{Binding WorkflowEditorVM.EditingWorkflow.Name, UpdateSourceTrigger=PropertyChanged}" Padding="20,0" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold" Background="Transparent" BorderThickness="0"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Visibility="{Binding WorkflowEditorVM.IsNotFtpDestination, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Save to Destination" Foreground="{DynamicResource Brush_Text_Secondary}" FontSize="13" Margin="4,24,0,8"/>
                        <Border Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" Padding="8,4" MinHeight="64" Effect="{StaticResource StandardShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding WorkflowEditorVM.EditingWorkflow.TargetPath, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="12,0" FontSize="14"/>
                                <Button Grid.Column="1" Content="{Binding WorkflowEditorVM.BrowseButtonText}" Command="{Binding WorkflowEditorVM.SearchDestinationCommand}" Padding="24,0" Style="{StaticResource ModernCardButtonStyle}" 
                                        FontWeight="Bold" Height="40" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- SMB Credentials (Conditional) -->
                    <StackPanel Visibility="{Binding WorkflowEditorVM.IsSmbDestination, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,24,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="User" Foreground="{DynamicResource Brush_Text_Secondary}" FontSize="13" Margin="4,0,0,8"/>
                                <Border Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" MinHeight="64" Effect="{StaticResource StandardShadow}">
                                    <TextBox Text="{Binding WorkflowEditorVM.EditingWorkflow.SmbUser, UpdateSourceTrigger=PropertyChanged}" Padding="20,0" VerticalContentAlignment="Center" FontSize="15" Background="Transparent" BorderThickness="0"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Password" Foreground="{DynamicResource Brush_Text_Secondary}" FontSize="13" Margin="4,0,0,8"/>
                                <Border Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" MinHeight="64" Effect="{StaticResource StandardShadow}">
                                    <Grid>
                                        <!-- Hidden Password (PasswordBox) -->
                                        <PasswordBox local:PasswordBoxHelper.Attach="True" 
                                                     local:PasswordBoxHelper.Password="{Binding WorkflowEditorVM.EditingWorkflow.SmbPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="20,0,50,0" VerticalContentAlignment="Center" FontSize="15" Background="Transparent" BorderThickness="0">
                                            <PasswordBox.Style>
                                                <Style TargetType="PasswordBox">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding WorkflowEditorVM.IsPasswordVisible}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </PasswordBox.Style>
                                        </PasswordBox>
                                        <!-- Shown Password (TextBox) -->
                                        <TextBox Text="{Binding WorkflowEditorVM.EditingWorkflow.SmbPassword, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="20,0,50,0" VerticalContentAlignment="Center" FontSize="15" Background="Transparent" BorderThickness="0">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding WorkflowEditorVM.IsPasswordVisible}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                        <!-- Toggle Button -->
                                        <Button Command="{Binding WorkflowEditorVM.TogglePasswordVisibilityCommand}" 
                                                Style="{StaticResource IconButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                                            <Path Width="22" Height="22" Stretch="Uniform" Fill="{DynamicResource Brush_Text_Primary}">
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Setter Property="Data" Value="{StaticResource Icon_Eye_Off}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding WorkflowEditorVM.IsPasswordVisible}" Value="True">
                                                                <Setter Property="Data" Value="{StaticResource Icon_Eye}"/>
                                                                <Setter Property="Fill" Value="{DynamicResource Brush_Accent}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                        </Button>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- FTP/SFTP Settings (Conditional) -->
                    <StackPanel Visibility="{Binding WorkflowEditorVM.IsFtpDestination, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,24,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="Server address" Foreground="{DynamicResource Brush_Text_Secondary}" FontSize="13" Margin="4,0,0,8"/>
                                <Border Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" MinHeight="64" Effect="{StaticResource StandardShadow}">
                                    <TextBox Text="{Binding WorkflowEditorVM.EditingWorkflow.FtpServer, UpdateSourceTrigger=PropertyChanged}" Padding="20,0" VerticalContentAlignment="Center" FontSize="15" Background="Transparent" BorderThickness="0"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Port" Foreground="{DynamicResource Brush_Text_Secondary}" FontSize="13" Margin="4,0,0,8"/>
                                <Border Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" MinHeight="64" Effect="{StaticResource StandardShadow}">
                                    <TextBox Text="{Binding WorkflowEditorVM.EditingWorkflow.FtpPort, UpdateSourceTrigger=PropertyChanged}" Padding="20,0" VerticalContentAlignment="Center" FontSize="15" Background="Transparent" BorderThickness="0"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Folder" Foreground="{DynamicResource Brush_Text_Secondary}" FontSize="13" Margin="4,24,0,8"/>
                        <Border Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" MinHeight="64" Effect="{StaticResource StandardShadow}">
                            <TextBox Text="{Binding WorkflowEditorVM.EditingWorkflow.FtpRemoteFolder, UpdateSourceTrigger=PropertyChanged}" Padding="20,0" VerticalContentAlignment="Center" FontSize="15" Background="Transparent" BorderThickness="0"/>
                        </Border>

                        <Grid Margin="0,24,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="Protocol" Foreground="{DynamicResource Brush_Text_Secondary}" FontSize="13" Margin="4,0,0,8"/>
                                <Border Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" MinHeight="64" Effect="{StaticResource StandardShadow}">
                                    <ComboBox SelectedValue="{Binding WorkflowEditorVM.EditingWorkflow.FtpProtocol}" SelectedValuePath="Content" Padding="20,0" VerticalContentAlignment="Center" FontSize="15" Background="Transparent" BorderThickness="0">
                                        <ComboBoxItem Content="FTP"/>
                                        <ComboBoxItem Content="SFTP"/>
                                    </ComboBox>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Encryption" Foreground="{DynamicResource Brush_Text_Secondary}" FontSize="13" Margin="4,0,0,8"/>
                                <Border Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" MinHeight="64" Effect="{StaticResource StandardShadow}">
                                    <ComboBox SelectedValue="{Binding WorkflowEditorVM.EditingWorkflow.FtpEncryption}" SelectedValuePath="Content" Padding="20,0" VerticalContentAlignment="Center" FontSize="15" Background="Transparent" BorderThickness="0">
                                        <ComboBoxItem Content="None"/>
                                        <ComboBoxItem Content="SSL/TLS"/>
                                        <ComboBoxItem Content="Implicit"/>
                                    </ComboBox>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Authentication Type" Foreground="{DynamicResource Brush_Text_Secondary}" FontSize="13" Margin="4,24,0,8"/>
                        <Border Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" MinHeight="64" Effect="{StaticResource StandardShadow}">
                            <ComboBox SelectedValue="{Binding WorkflowEditorVM.EditingWorkflow.FtpAuthType}" SelectedValuePath="Content" Padding="20,0" VerticalContentAlignment="Center" FontSize="15" Background="Transparent" BorderThickness="0">
                                <ComboBoxItem Content="Normal"/>
                                <ComboBoxItem Content="Anonymous"/>
                            </ComboBox>
                        </Border>

                        <Grid Margin="0,24,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="Login" Foreground="{DynamicResource Brush_Text_Secondary}" FontSize="13" Margin="4,0,0,8"/>
                                <Border Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" MinHeight="64" Effect="{StaticResource StandardShadow}">
                                    <TextBox Text="{Binding WorkflowEditorVM.EditingWorkflow.FtpLogin, UpdateSourceTrigger=PropertyChanged}" Padding="20,0" VerticalContentAlignment="Center" FontSize="15" Background="Transparent" BorderThickness="0"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Password" Foreground="{DynamicResource Brush_Text_Secondary}" FontSize="13" Margin="4,0,0,8"/>
                                <Border Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" MinHeight="64" Effect="{StaticResource StandardShadow}">
                                    <Grid>
                                        <!-- Hidden Password (PasswordBox) -->
                                        <PasswordBox local:PasswordBoxHelper.Attach="True" 
                                                     local:PasswordBoxHelper.Password="{Binding WorkflowEditorVM.EditingWorkflow.FtpPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="20,0,50,0" VerticalContentAlignment="Center" FontSize="15" Background="Transparent" BorderThickness="0">
                                            <PasswordBox.Style>
                                                <Style TargetType="PasswordBox">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding WorkflowEditorVM.IsPasswordVisible}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </PasswordBox.Style>
                                        </PasswordBox>
                                        <!-- Shown Password (TextBox) -->
                                        <TextBox Text="{Binding WorkflowEditorVM.EditingWorkflow.FtpPassword, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="20,0,50,0" VerticalContentAlignment="Center" FontSize="15" Background="Transparent" BorderThickness="0">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding WorkflowEditorVM.IsPasswordVisible}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                        <!-- Toggle Button -->
                                        <Button Command="{Binding WorkflowEditorVM.TogglePasswordVisibilityCommand}" 
                                                Style="{StaticResource IconButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                                            <Path Width="22" Height="22" Stretch="Uniform" Fill="{DynamicResource Brush_Text_Primary}">
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Setter Property="Data" Value="{StaticResource Icon_Eye_Off}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding WorkflowEditorVM.IsPasswordVisible}" Value="True">
                                                                <Setter Property="Data" Value="{StaticResource Icon_Eye}"/>
                                                                <Setter Property="Fill" Value="{DynamicResource Brush_Accent}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                        </Button>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <!-- ================= RIGHT COLUMN: SCAN CONFIGURATION ================= -->
                <StackPanel Grid.Column="1">
                    <!-- File Format -->
                    <TextBlock Text="File Format" Foreground="{DynamicResource Brush_Text_Secondary}" FontSize="13" Margin="4,0,0,8"/>
                    <UniformGrid Columns="2" Margin="-4,0,-4,0">
                        <RadioButton Style="{StaticResource VisualTileRadioButtonStyle}" IsChecked="{Binding WorkflowEditorVM.EditingWorkflow.FileFormat, Converter={StaticResource EnumValueToBooleanConverter}, ConverterParameter=PDF}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,4">
                                <TextBlock Text="PDF" FontWeight="Heavy" FontSize="20" HorizontalAlignment="Center" Foreground="{DynamicResource Brush_Text_Primary}"/>
                                <TextBlock Text="Document" FontSize="11" Opacity="0.5" HorizontalAlignment="Center" Foreground="{DynamicResource Brush_Text_Secondary}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource VisualTileRadioButtonStyle}" IsChecked="{Binding WorkflowEditorVM.EditingWorkflow.FileFormat, Converter={StaticResource EnumValueToBooleanConverter}, ConverterParameter=JPG}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,4">
                                <TextBlock Text="JPG" FontWeight="Heavy" FontSize="20" HorizontalAlignment="Center" Foreground="{DynamicResource Brush_Text_Primary}"/>
                                <TextBlock Text="Image format" FontSize="11" Opacity="0.5" HorizontalAlignment="Center" Foreground="{DynamicResource Brush_Text_Secondary}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </RadioButton>
                    </UniformGrid>

                    <!-- Color Mode -->
                    <TextBlock Text="Color Mode" Foreground="{DynamicResource Brush_Text_Secondary}" FontSize="13" Margin="4,24,0,8"/>
                    <UniformGrid Columns="3" Margin="-4,0,-4,0">
                        <RadioButton Style="{StaticResource VisualTileRadioButtonStyle}" IsChecked="{Binding WorkflowEditorVM.EditingWorkflow.ScanMode, Converter={StaticResource EnumValueToBooleanConverter}, ConverterParameter=Color}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,8">
                                <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z" Fill="{StaticResource Brush_Rainbow}" Width="28" Height="28" Stretch="Uniform" Margin="0,0,0,12"/>
                                <TextBlock Text="Color" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Foreground="{DynamicResource Brush_Text_Primary}"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource VisualTileRadioButtonStyle}" IsChecked="{Binding WorkflowEditorVM.EditingWorkflow.ScanMode, Converter={StaticResource EnumValueToBooleanConverter}, ConverterParameter=Grayscale}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,8">
                                <Grid Width="28" Height="28" Margin="0,0,0,12" Opacity="0.6">
                                    <Ellipse Fill="{DynamicResource Brush_Text_Secondary}"/>
                                    <Ellipse Stroke="White" StrokeThickness="2"/>
                                </Grid>
                                <TextBlock Text="Grayscale" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Foreground="{DynamicResource Brush_Text_Primary}"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource VisualTileRadioButtonStyle}" IsChecked="{Binding WorkflowEditorVM.EditingWorkflow.ScanMode, Converter={StaticResource EnumValueToBooleanConverter}, ConverterParameter=B&amp;W}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,8">
                                <Grid Width="28" Height="28" Margin="0,0,0,12" Opacity="0.5">
                                    <Ellipse Fill="Black"/>
                                    <Ellipse Fill="White" Width="14" Height="28" HorizontalAlignment="Left"/>
                                    <Ellipse Stroke="Black" StrokeThickness="2"/>
                                </Grid>
                                <TextBlock Text="B &amp; W" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Foreground="{DynamicResource Brush_Text_Primary}"/>
                            </StackPanel>
                        </RadioButton>
                    </UniformGrid>

                    <!-- Sides -->
                    <TextBlock Text="Sides" Foreground="{DynamicResource Brush_Text_Secondary}" FontSize="13" Margin="4,24,0,8"/>
                    <UniformGrid Columns="2" Margin="-4,0,-4,0">
                        <RadioButton Style="{StaticResource VisualTileRadioButtonStyle}" IsChecked="{Binding WorkflowEditorVM.EditingWorkflow.Sides, Converter={StaticResource EnumValueToBooleanConverter}, ConverterParameter=1 Sided}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,8">
                                <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M13,9V3.5L18.5,9H13Z" Fill="{DynamicResource Brush_Text_Primary}" Width="24" Height="24" Stretch="Uniform" Margin="0,0,12,0" Opacity="0.7"/>
                                <TextBlock Text="1 Sided" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" Foreground="{DynamicResource Brush_Text_Primary}"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource VisualTileRadioButtonStyle}" IsChecked="{Binding WorkflowEditorVM.EditingWorkflow.Sides, Converter={StaticResource EnumValueToBooleanConverter}, ConverterParameter=2 Sided}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,8">
                                <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M13,9V3.5L18.5,9H13M17,14H7V12H17V14M14,18H7V16H14V18Z" Fill="{DynamicResource Brush_Text_Primary}" Width="24" Height="24" Stretch="Uniform" Margin="0,0,12,0" Opacity="0.7"/>
                                <TextBlock Text="2 Sided (Duplex)" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" Foreground="{DynamicResource Brush_Text_Primary}"/>
                            </StackPanel>
                        </RadioButton>
                    </UniformGrid>

                    <!-- Paper Size & Resolution -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Text="Paper Size" Foreground="{DynamicResource Brush_Text_Secondary}" FontSize="13" Margin="4,24,0,8"/>
                            <ComboBox SelectedValue="{Binding WorkflowEditorVM.EditingWorkflow.PaperSize}" SelectedValuePath="Content" Padding="16,12" FontSize="15" FontWeight="SemiBold">
                                <ComboBoxItem Content="Auto"/>
                                <ComboBoxItem Content="A3"/>
                                <ComboBoxItem Content="A4"/>
                                <ComboBoxItem Content="A5"/>
                                <ComboBoxItem Content="Letter"/>
                                <ComboBoxItem Content="Long Paper"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Resolution" Foreground="{DynamicResource Brush_Text_Secondary}" FontSize="13" Margin="4,24,0,8"/>
                            <ComboBox SelectedValue="{Binding WorkflowEditorVM.EditingWorkflow.Resolution}" SelectedValuePath="Content" Padding="16,12" FontSize="15" FontWeight="SemiBold">
                                <ComboBoxItem Content="200dpi"/>
                                <ComboBoxItem Content="300dpi"/>
                                <ComboBoxItem Content="600dpi"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </ScrollViewer>


    </Grid>
</UserControl>
