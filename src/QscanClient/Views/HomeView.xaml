<UserControl x:Class="QscanClient.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:QscanClient"
             xmlns:views="clr-namespace:QscanClient.Views">
    <Grid Background="Transparent">
        <Grid.ColumnDefinitions>
            <!-- Hero Column (Active Scan) -->
            <ColumnDefinition Width="Auto"/>
            <!-- Content Column (History) -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Hero Section (Visible only when scanning) -->
        <Border Grid.Column="0" Width="360" Background="{DynamicResource Brush_Background_Base}" 
                CornerRadius="10,0,0,0" Margin="0" 
                Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
            <Grid Margin="32,48,32,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,32">
                    <Grid>
                        <TextBlock Text="Live Session" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource Brush_Text_Primary}"/>
                        <Ellipse HorizontalAlignment="Right" VerticalAlignment="Center" Width="10" Height="10" Fill="Red" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.2" Duration="0:0:0.8"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Grid>
                    <TextBlock Text="Scanning from Q30" FontSize="14" Foreground="{DynamicResource Brush_Text_Secondary}" Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Row="1" Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="20" VerticalAlignment="Top" Padding="24" Effect="{DynamicResource WarmGlow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Indeterminate Scanning Animation Area -->
                        <Grid Width="180" Height="180" Margin="0,20">
                            <!-- Background track -->
                            <Ellipse Stroke="{DynamicResource Brush_Text_Secondary}" StrokeThickness="4" Opacity="0.1"/>
                            
                            <!-- Pulsing/Rotating Indeterminate Segment -->
                            <Path x:Name="IndeterminateSegment" Stroke="{DynamicResource Brush_Accent}" StrokeThickness="6" 
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M 90,5 A 85,85 0 0,1 150,30">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard x:Name="RotateStoryboard">
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" 
                                                                             From="0" To="360" Duration="0:0:1.5"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="RotateStoryboard"/>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                                <Path.RenderTransform>
                                    <RotateTransform CenterX="90" CenterY="90"/>
                                </Path.RenderTransform>
                            </Path>
                            
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding CurrentScanningPage}" FontSize="48" FontWeight="Bold" 
                                           Foreground="{DynamicResource Brush_Text_Primary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Pages Scanned" FontSize="14" Foreground="{DynamicResource Brush_Text_Secondary}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Middle: Recent Scans History -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="32,48,32,24">
                <TextBlock Text="Recent Scans" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource Brush_Text_Primary}"/>
            </Grid>

            <ScrollViewer Grid.Row="1" Margin="0" HorizontalScrollBarVisibility="Disabled" ClipToBounds="False">
                <Grid Margin="48,10,24,48" ClipToBounds="False">
                    <WrapPanel Orientation="Horizontal" ClipToBounds="False">
                        <ItemsControl ItemsSource="{Binding Batches}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" ItemWidth="{Binding Path=CardWidth, RelativeSource={RelativeSource AncestorType=views:HomeView}}"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <local:DocCard Title="{Binding Title}" 
                                                   Date="{Binding FullDateFormatted}" 
                                                   Subtitle="{Binding ImageCountFormatted}"
                                                   Command="{Binding DataContext.SelectBatchCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                   CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </WrapPanel>
                </Grid>
            </ScrollViewer>
        </Grid>

    </Grid>
</UserControl>
