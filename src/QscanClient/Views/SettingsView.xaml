<UserControl x:Class="QscanClient.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="Transparent" Margin="32">
        <StackPanel>
            <TextBlock Text="Settings" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource Brush_Text_Primary}" Margin="0,0,0,32"/>
            
            <Border Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" Padding="24" BorderBrush="{DynamicResource Brush_Border_Subtle}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel>
                        <TextBlock Text="Appearance" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Brush_Text_Primary}"/>
                        <TextBlock Text="Toggle between Light and Dark themes" FontSize="13" Foreground="{DynamicResource Brush_Text_Secondary}" Margin="0,4,0,0"/>
                    </StackPanel>
                    
                    <CheckBox Grid.Column="1" Style="{StaticResource {x:Type CheckBox}}" 
                              IsChecked="{Binding IsDarkTheme}" 
                              VerticalAlignment="Center">
                        <CheckBox.Template>
                            <ControlTemplate TargetType="CheckBox">
                                <Border x:Name="Track" Width="44" Height="22" Background="#20000000" CornerRadius="11">
                                    <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="White" HorizontalAlignment="Left" Margin="2">
                                        <Ellipse.RenderTransform>
                                            <TranslateTransform X="0"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Track" Property="Background" Value="{DynamicResource Brush_Accent_Gradient}"/>
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="22" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </CheckBox.Template>
                    </CheckBox>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
