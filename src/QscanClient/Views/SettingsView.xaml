<UserControl x:Class="QscanClient.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:QscanClient"
             xmlns:vm="clr-namespace:QscanClient.ViewModels"
             xmlns:conv="clr-namespace:QscanClient.Converters">
    <UserControl.Resources>
        <!-- Enum to Boolean Converter for RadioButtons -->
        <conv:EnumValueToBooleanConverter x:Key="EnumValueToBooleanConverter"/>
        <conv:EnumValueToVisibilityConverter x:Key="EnumValueToVisibilityConverter"/>

        <!-- Icons -->
        <Geometry x:Key="Icon_General">M12 1.998a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Zm8.344 4.518a2.01 2.01 0 0 0-2.612-1.255l-1.607.6a.75.75 0 0 0-.416.381 4.086 4.086 0 0 1-7.386.01.75.75 0 0 0-.415-.38L6.28 5.264A2.007 2.007 0 0 0 4.816 9L8 10.31v3.148l-1.972 5.713a1.956 1.956 0 0 0 3.683 1.321l1.846-4.958a.48.48 0 0 1 .9-.002l1.882 5.009a1.94 1.94 0 0 0 3.652-1.315L16 13.446v-3.134l3.195-1.307a2.01 2.01 0 0 0 1.149-2.489Z</Geometry>
        <Geometry x:Key="Icon_Scanner">M2.747 15a.75.75 0 0 1 .743.648l.007.102v3.502l.007.128a1.25 1.25 0 0 0 1.115 1.116l.128.006h3.5l.102.007a.75.75 0 0 1 0 1.486l-.102.007h-3.5l-.167-.005a2.75 2.75 0 0 1-2.578-2.57l-.005-.175V15.75l.007-.102A.75.75 0 0 1 2.747 15Zm18.5 0a.75.75 0 0 1 .743.648l.007.102v3.502a2.75 2.75 0 0 1-2.582 2.745l-.168.005h-3.5a.75.75 0 0 1-.102-1.493l.102-.007h3.5a1.25 1.25 0 0 0 1.244-1.122l.006-.128V15.75a.75.75 0 0 1 .75-.75ZM12 15a1 1 0 0 1 .117 1.993L12 17H8a1 1 0 0 1-.116-1.993L8 15h4Zm4-4a1 1 0 0 1 .117 1.993L16 13H8a1 1 0 0 1-.116-1.993L8 11h8ZM8.247 2a.75.75 0 0 1 .102 1.493l-.102.007h-3.5a1.25 1.25 0 0 0-1.243 1.122l-.007.128v3.502a.75.75 0 0 1-1.493.102l-.007-.102V4.75A2.75 2.75 0 0 1 4.58 2.005L4.747 2h3.5Zm11 0 .168.005a2.75 2.75 0 0 1 2.577 2.57l.005.175v3.502l-.007.102a.75.75 0 0 1-1.486 0l-.007-.102V4.75l-.006-.128a1.25 1.25 0 0 0-1.116-1.116l-.128-.006h-3.5l-.102-.007a.75.75 0 0 1 0-1.486L15.747 2h3.5ZM16 7a1 1 0 0 1 .117 1.993L16 9H8a1 1 0 0 1-.116-1.993L8 7h8Z</Geometry>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track" Width="44" Height="22" Background="#20000000" CornerRadius="11">
                            <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="White" HorizontalAlignment="Left" Margin="2">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform X="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource Brush_Accent_Gradient}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="22" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Navigation Button Style -->
        <Style x:Key="SettingsNavButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush_Text_Secondary}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Height" Value="54"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12" Padding="20,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border x:Name="activeIndicator" Width="4" Height="22" Background="{DynamicResource Brush_Accent}" CornerRadius="2" HorizontalAlignment="Left" Margin="-20,0,0,0" Visibility="Collapsed"/>
                                
                                <Viewbox Width="20" Height="20" Grid.Column="0" HorizontalAlignment="Left">
                                    <Path x:Name="iconPath" Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" 
                                          Fill="{TemplateBinding Foreground}" Stretch="Uniform"/>
                                </Viewbox>
                                
                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush_Sidebar_Hover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Brush_Text_Primary}"/>
                                <Setter TargetName="iconPath" Property="Fill" Value="{DynamicResource Brush_Text_Primary}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush_Sidebar_Selected}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Brush_Accent}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="activeIndicator" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="iconPath" Property="Fill" Value="{DynamicResource Brush_Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Settings" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource Brush_Text_Primary}" Margin="32,48,32,32"/>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/> <!-- Navigation sidebar -->
                <ColumnDefinition Width="*"/>   <!-- Content area -->
            </Grid.ColumnDefinitions>

            <!-- Navigation Sidebar -->
            <StackPanel Grid.Column="0" Margin="32,0,16,0">
                <RadioButton Content="General" 
                             GroupName="SettingsCategory"
                             Tag="{StaticResource Icon_General}"
                             Style="{StaticResource SettingsNavButtonStyle}" 
                             IsChecked="{Binding SelectedSettingsCategory, Converter={StaticResource EnumValueToBooleanConverter}, ConverterParameter={x:Static vm:SettingsCategory.General}}"/>
                <RadioButton Content="Scan Settings" 
                             GroupName="SettingsCategory"
                             Tag="{StaticResource Icon_Scanner}"
                             Style="{StaticResource SettingsNavButtonStyle}" 
                             IsChecked="{Binding SelectedSettingsCategory, Converter={StaticResource EnumValueToBooleanConverter}, ConverterParameter={x:Static vm:SettingsCategory.ScanSettings}}"/>
            </StackPanel>

            <!-- Settings Content -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" PanningMode="Both">
                <StackPanel Margin="16,0,32,24">
                    
                    <!-- General Section -->
                    <StackPanel Visibility="{Binding SelectedSettingsCategory, Converter={StaticResource EnumValueToVisibilityConverter}, ConverterParameter={x:Static vm:SettingsCategory.General}}">
                        
                        <!-- Client Name -->
                        <Border Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" Padding="24" BorderBrush="{DynamicResource Brush_Border_Subtle}" BorderThickness="1" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Client Name" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Brush_Text_Primary}"/>
                                    <TextBlock Text="Name of this device as shown in reports" FontSize="13" Foreground="{DynamicResource Brush_Text_Secondary}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding ClientName, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Quick Scan Folder -->
                        <Border Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" Padding="24" BorderBrush="{DynamicResource Brush_Border_Subtle}" BorderThickness="1" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock Text="Quick Scan Folder" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Brush_Text_Primary}" HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding QuickScanFolder}" FontSize="13" Foreground="{DynamicResource Brush_Text_Secondary}" Margin="0,4,0,0" TextWrapping="Wrap" HorizontalAlignment="Left"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Browse..." 
                                        Command="{Binding BrowseQuickScanFolderCommand}"
                                        Padding="24,0" VerticalAlignment="Center"
                                        Style="{DynamicResource ModernCardButtonStyle}"
                                        FontWeight="Bold" Height="40" Margin="16,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Theme -->
                        <Border Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" Padding="24" BorderBrush="{DynamicResource Brush_Border_Subtle}" BorderThickness="1" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Theme" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Brush_Text_Primary}"/>
                                    <TextBlock Text="Toggle between Light and Dark themes" FontSize="13" Foreground="{DynamicResource Brush_Text_Secondary}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding IsDarkTheme}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Version -->
                        <Border Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" Padding="24" BorderBrush="{DynamicResource Brush_Border_Subtle}" BorderThickness="1" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Version" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Brush_Text_Primary}"/>
                                    <TextBlock Text="Current software version installed on this device" FontSize="13" Foreground="{DynamicResource Brush_Text_Secondary}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding AppVersion}" FontSize="15" FontWeight="Medium" Foreground="{DynamicResource Brush_Text_Secondary}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Scan Settings Section -->
                    <StackPanel Visibility="{Binding SelectedSettingsCategory, Converter={StaticResource EnumValueToVisibilityConverter}, ConverterParameter={x:Static vm:SettingsCategory.ScanSettings}}">
                        <!-- Auto Crop -->
                        <Border Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" Padding="24" BorderBrush="{DynamicResource Brush_Border_Subtle}" BorderThickness="1" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Auto Crop" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Brush_Text_Primary}"/>
                                    <TextBlock Text="Automatically crop scanned images to their actual size" FontSize="13" Foreground="{DynamicResource Brush_Text_Secondary}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding AutoCrop}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Auto Deskew -->
                        <Border Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" Padding="24" BorderBrush="{DynamicResource Brush_Border_Subtle}" BorderThickness="1" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Auto Deskew" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Brush_Text_Primary}"/>
                                    <TextBlock Text="Automatically correct skewed images into straight ones" FontSize="13" Foreground="{DynamicResource Brush_Text_Secondary}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding AutoDeskew}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Remove Blank Page -->
                        <Border Background="{DynamicResource Brush_Elevation_Card}" CornerRadius="12" Padding="24" BorderBrush="{DynamicResource Brush_Border_Subtle}" BorderThickness="1" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Remove Blank Page" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Brush_Text_Primary}"/>
                                    <TextBlock Text="Automatically detect and remove blank pages from the batch" FontSize="13" Foreground="{DynamicResource Brush_Text_Secondary}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding RemoveBlankPage}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>


