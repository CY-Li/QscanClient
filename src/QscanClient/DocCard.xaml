<UserControl x:Class="QscanClient.DocCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             Width="164" Height="224" Margin="0,0,20,20">
    <UserControl.Resources>
        <Style x:Key="DocCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush_Background_Surface}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#1FFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{StaticResource StandardShadow}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252525"/>
                    <Setter Property="BorderBrush" Value="#40FFFFFF"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.02" ScaleY="1.02" CenterX="82" CenterY="112"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Style="{StaticResource DocCardBorderStyle}">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Realistic Document Preview Placeholder -->
                <Border Background="White" CornerRadius="2" Margin="6,2,6,12" Height="140">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                    </Border.Effect>
                    <Grid Margin="12,16">
                        <StackPanel>
                            <!-- Header lines -->
                            <Rectangle Fill="{StaticResource Brush_Accent}" Height="2" Width="20" HorizontalAlignment="Left" Margin="0,0,0,8" Opacity="0.8"/>
                            <Rectangle Fill="#E0E0E0" Height="2" Margin="0,0,0,4"/>
                            <Rectangle Fill="#F0F0F0" Height="2" Margin="0,0,10,4"/>
                            
                            <!-- Body lines -->
                            <StackPanel Margin="0,12,0,0">
                                <Rectangle Fill="#F5F5F5" Height="1.5" Margin="0,0,0,3"/>
                                <Rectangle Fill="#F5F5F5" Height="1.5" Margin="0,0,0,3"/>
                                <Rectangle Fill="#F5F5F5" Height="1.5" Margin="0,0,4,3"/>
                                <Rectangle Fill="#F5F5F5" Height="1.5" Margin="0,0,0,3"/>
                                <Rectangle Fill="#F5F5F5" Height="1.5" Margin="0,0,8,3"/>
                                <Rectangle Fill="#F5F5F5" Height="1.5" Margin="0,0,0,3"/>
                                <Rectangle Fill="#F5F5F5" Height="1.5" Margin="0,0,2,3"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Mini "Stamp" or Logo indicator -->
                         <Ellipse Fill="{StaticResource Brush_Accent}" Width="8" Height="8" VerticalAlignment="Bottom" HorizontalAlignment="Right" Opacity="0.1"/>
                    </Grid>
                </Border>

                <!-- File Info -->
                <StackPanel Grid.Row="1" Margin="2,0">
                    <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                               Foreground="{StaticResource Brush_Text_Primary}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,0,0,2"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Date, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                   Foreground="{StaticResource Brush_Text_Secondary}" FontSize="11" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Size, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                   Foreground="{StaticResource Brush_Text_Secondary}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>