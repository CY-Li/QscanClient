<Application x:Class="QscanClient.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:QscanClient"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Default Theme -->
                <ResourceDictionary Source="/Themes/LightTheme.xaml"/>
                <!-- Component Library -->
                <ResourceDictionary Source="/Themes/ControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <LinearGradientBrush x:Key="Brush_Rainbow" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF3D00" Offset="0"/>   <!-- Red-Orange -->
                <GradientStop Color="#FFAB00" Offset="0.25"/> <!-- Yellow -->
                <GradientStop Color="#00C853" Offset="0.5"/>  <!-- Green -->
                <GradientStop Color="#2962FF" Offset="0.75"/> <!-- Blue -->
                <GradientStop Color="#D500F9" Offset="1"/>    <!-- Purple -->
            </LinearGradientBrush>

            <!-- Converters -->
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            
            <!-- Shared Gallery & Workflow Styles -->
            <Style x:Key="BadgeStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="Padding" Value="6,2"/>
                <Setter Property="Margin" Value="0,0,8,0"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
            </Style>

            <Style x:Key="OCRBadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgeStyle}">
                <Setter Property="Background" Value="#33FF5E00"/>
                <Setter Property="BorderBrush" Value="#66FF5E00"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#FFFF8B4D"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </Style.Resources>
            </Style>

            <Style x:Key="AIBadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgeStyle}">
                <Setter Property="Background" Value="#33FFB800"/>
                <Setter Property="BorderBrush" Value="#66FFB800"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#FFFFD266"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </Style.Resources>
            </Style>

            <Style x:Key="NASBadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgeStyle}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Brush_Text_Secondary}"/>
                <Setter Property="Opacity" Value="0.8"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource Brush_Text_Secondary}"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </Style.Resources>
            </Style>

            <Style x:Key="ModernCardButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Brush_Accent}"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush_Accent}"/>
                <Setter Property="Padding" Value="16,6"/>
                <Setter Property="MinWidth" Value="80"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="UseLayoutRounding" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush_Accent}"/>
                                    <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush_Accent}"/>
                                    <Setter TargetName="border" Property="Effect" Value="{StaticResource WarmGlow}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>



            <!-- Sidebar Button Base template structure (Common for both) -->
            <Style x:Key="SidebarButtonBase" TargetType="Control">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush_Text_Secondary}"/>
                <Setter Property="Height" Value="60"/>
                <Setter Property="Margin" Value="4,2"/>
            </Style>

            <!-- Global Style: Sidebar RadioButton (Used in Main Navigation) -->
            <Style x:Key="SidebarRadioButtonStyle" TargetType="RadioButton" BasedOn="{StaticResource SidebarButtonBase}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Grid Background="Transparent">
                                <Border x:Name="Indicator" Background="{DynamicResource Brush_Accent}" 
                                        Width="3" Height="24" HorizontalAlignment="Left" 
                                        CornerRadius="1.5" Visibility="Collapsed" Margin="0"/>
                                <Border x:Name="HoverBd" Background="{TemplateBinding Background}" CornerRadius="4" Margin="6,0">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Viewbox Width="20" Height="20" Margin="0,0,0,4">
                                            <Path x:Name="IconPath" Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" 
                                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" Stretch="Uniform"/>
                                        </Viewbox>
                                        <TextBlock x:Name="TextLabel" Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}" 
                                                   FontSize="11" FontWeight="Normal" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" 
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="HoverBd" Property="Background" Value="{DynamicResource Brush_Sidebar_Hover}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Brush_Text_Primary}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="HoverBd" Property="Background" Value="{DynamicResource Brush_Sidebar_Selected}"/> 
                                    <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource Brush_Accent_Gradient}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Brush_Text_Primary}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource Brush_Text_Secondary}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Global Style: Sidebar Button (Used for Actions) -->
            <Style x:Key="SidebarButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Height" Value="50"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="HoverBd" Background="{TemplateBinding Background}" CornerRadius="4">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                    <Viewbox Width="16" Height="16" Margin="0,0,12,0">
                                        <Path x:Name="IconPath" Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" 
                                              Fill="{TemplateBinding Foreground}" Stretch="Uniform"/>
                                    </Viewbox>
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="HoverBd" Property="Background" Value="{DynamicResource Brush_Sidebar_Hover}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Brush_Text_Primary}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Global Style: Sidebar Action Button -->
            <Style x:Key="SidebarActionStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Height" Value="50"/>
                <Setter Property="Margin" Value="10,4"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="HoverBd" Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="HoverBd" Property="Background" Value="{DynamicResource Brush_Sidebar_Hover}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

