<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Sunset Lava Color Palette -->
    <SolidColorBrush x:Key="Brush_Background_Base" Color="#0F0A05"/>
    <SolidColorBrush x:Key="Brush_Background_Surface" Color="#1B1410"/>
    <SolidColorBrush x:Key="Brush_Elevation_Card" Color="#2A221C"/>
    
    <LinearGradientBrush x:Key="Brush_Accent_Gradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF5E00" Offset="0"/>
        <GradientStop Color="#FFB800" Offset="1"/>
    </LinearGradientBrush>

    <!-- Dynamic Theme Brushes -->
    <SolidColorBrush x:Key="Brush_Accent" Color="#FF5E00"/>
    <SolidColorBrush x:Key="Brush_Accent_Glow" Color="#FFB800"/>
    <SolidColorBrush x:Key="Brush_Text_Primary" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Brush_Text_Secondary" Color="#B5A89D"/>
    <SolidColorBrush x:Key="Brush_Border_Subtle" Color="#1FFFFFFF"/>

    <!-- Depth & Shadows -->
    <DropShadowEffect x:Key="StandardShadow" BlurRadius="20" Opacity="0.4" ShadowDepth="4" Color="Black"/>
    <DropShadowEffect x:Key="WarmGlow" BlurRadius="25" Opacity="0.6" ShadowDepth="0" Color="#261200"/>
    
    <!-- Sidebar Button Internal Triggers -->
    <SolidColorBrush x:Key="Brush_Sidebar_Hover" Color="#1AFFFFFF"/>
    <SolidColorBrush x:Key="Brush_Sidebar_Selected" Color="#3D291F"/> <!-- Warm deep amber tint -->
    <SolidColorBrush x:Key="Brush_Card_Hover" Color="#332A22"/> <!-- Slightly lighter warm brown -->
</ResourceDictionary>
